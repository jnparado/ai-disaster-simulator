# Copy to .env.local for local development:
#   cp .env.example .env.local

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="AI Disaster Impact Simulator"

# Default simulation settings
NEXT_PUBLIC_DEFAULT_CITY="Davao City"
NEXT_PUBLIC_DEFAULT_DISASTER=flood

# Mapbox (required for disaster impact map)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# SMS Calamity Alerts
ALERT_PHONE_NUMBER=
NEXT_PUBLIC_ALERT_PHONE=
NEXT_PUBLIC_SMS_ALERTS_AUTO=true
NEXT_PUBLIC_SMS_INTERVAL_MS=30000
CRON_SECRET=
SEMAPHORE_API_KEY=
# Or Twilio (international)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

AI_ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
